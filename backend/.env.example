# ===== LearnLoop Agent 环境配置 =====
# 复制此文件为 .env 并填入真实值

# ----- 数据库 -----
# 开发环境用 SQLite（零配置），生产环境用 MySQL
DATABASE_URL=sqlite+aiosqlite:///./learnloop.db
# DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/learnloop

# ----- LLM 模型 -----
# DeepSeek（默认主力模型，性价比最高）
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI / PPIO 代理（GPT-5.5）
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.ppio.cloud/v1

# 智谱 GLM
ZHIPU_API_KEY=xxx
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# MiMo（小米自研）
MIMO_API_KEY=xxx
MIMO_BASE_URL=https://api.mimo.xiaomi.com/v1

# 默认模型选择：deepseek-chat / gpt-5.5 / glm-5.2 / mimo-v2.5-pro
DEFAULT_MODEL=deepseek-chat

# ----- 应用配置 -----
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production
APP_HOST=0.0.0.0
APP_PORT=8000

# ----- 前端 -----
FRONTEND_URL=http://localhost:3000
